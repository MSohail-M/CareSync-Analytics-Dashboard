# Supabase — supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server only, never expose

# Retell webhook signature secret — Retell dashboard > Webhooks > Signing secret
RETELL_WEBHOOK_SECRET=your-retell-signing-secret

# App
NEXT_PUBLIC_APP_NAME=Call Dashboard
NEXT_PUBLIC_APP_URL=http://localhost:3000
